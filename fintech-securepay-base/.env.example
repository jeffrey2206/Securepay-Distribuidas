# Variables de entorno — Fintech SecurePay
# Copia este archivo como .env y rellena los valores correspondientes
# NUNCA subas el archivo .env ni las llaves *.pem al repositorio

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT RS256 ─────────────────────────────────────────────────────────────────
# Las llaves RSA se generan ejecutando el script: bash keypair.sh
# Los archivos resultantes (private.pem / public.pem) se leen en tiempo
# de ejecución por jwt.service.js y NO se almacenan en variables de entorno.
# JWT_SECRET se mantiene como referencia heredada pero NO se usa con RS256.
JWT_SECRET=

# ── Sentry (Observabilidad) ───────────────────────────────────────────────────
# Obtén tu DSN en: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
